# App Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AWS Cognito OAuth
COGNITO_DOMAIN=https://artispreneur-dev.auth.us-east-1.amazoncognito.com
COGNITO_CLIENT_ID=your_client_id_here
COGNITO_CLIENT_SECRET=your_client_secret_here
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_REGION=us-east-1

# Session & Auth
SESSION_SECRET=generate_random_32_char_string_here
AUTH_DEV_BYPASS=0

# AWS Services
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# DynamoDB
DYNAMODB_INSTANCE_TABLE=artispreneur-instances
DYNAMODB_USERS_TABLE=artispreneur-users
DYNAMODB_PROJECTS_TABLE=artispreneur-projects

# S3 Hub Storage
S3_HUB_BUCKET=artispreneur-hub
HUB_BACKEND=fs

# Bedrock AI
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_REGION=us-east-1

# Skills & Payments (Optional)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Feature Flags
ENABLE_SKILLS_MARKETPLACE=true
ENABLE_MULTI_AGENT=true
ENABLE_RAG_DAL=true
